{
  "name": "@repo/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sst shell -- next dev",
    "start": "sst shell -- next start",
    "build": "next build",
    "build:open-next": "open-next build",
    "build:analyze": "cross-env ANALYZE=true NEXT_PUBLIC_STAGE=dev sst shell -- next build",
    "test": "sst shell -- vitest run",
    "test:ui": "sst shell -- vitest --ui",
    "test:e2e": "sst shell -- playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "bun --cwd ../backend types:generate && oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "format": "oxfmt",
    "update-readme": "doctoc README.md",
    "postinstall": "tsx scripts/install-playwright"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.148",
    "@better-auth/oauth-provider": "1.5.4",
    "@better-auth/stripe": "1.5.4",
    "@daveyplate/better-auth-ui": "3.4.0",
    "@orpc/client": "1.13.8",
    "@orpc/tanstack-query": "1.13.8",
    "@posthog/nextjs-config": "1.0.0",
    "@repo/analytics": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/constants": "workspace:*",
    "@repo/design": "workspace:*",
    "@repo/flags": "workspace:*",
    "@repo/seo": "workspace:*",
    "@repo/utils": "workspace:*",
    "@tanstack/react-query": "5.79.0",
    "ai": "6.0.146",
    "better-auth": "1.5.4",
    "jotai": "2.12.4",
    "lucide-react": "0.475.0",
    "next": "15.3.6",
    "next-themes": "0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.3.6",
    "@opennextjs/aws": "3.6.2",
    "@playwright/test": "1.52.0",
    "@repo/backend": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "24.10.1",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "jsdom": "26.1.0",
    "tailwindcss": "4.1.7",
    "typescript": "5.9.3"
  }
}
