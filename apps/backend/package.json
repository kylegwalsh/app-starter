{
  "name": "@repo/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "sst shell -- vitest run",
    "test:ui": "sst shell -- vitest --ui",
    "auth:generate": "sst shell -- bunx @better-auth/cli generate --config ./core/auth.ts --output ./db/schema.prisma",
    "db:start": "bun db:get-url \"prisma db push && prisma studio --browser none\"",
    "db:push": "bun db:get-url \"prisma db push\"",
    "db:migrate": "tsx ./scripts/migrations/create-migration.ts",
    "db:migrate:deploy": "bun db:get-url \"prisma migrate deploy\"",
    "db:migrate:validate": "bun db:get-url \"tsx ./scripts/migrations/validate-migration.ts\"",
    "db:studio": "bun db:get-url \"prisma studio\"",
    "db:generate": "prisma generate",
    "db:get-url": "tsx ./scripts/get-deb-url.ts",
    "env:add": "tsx ./scripts/add-env.ts",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "format": "oxfmt",
    "types:generate": "tsc --emitDeclarationOnly",
    "update-readme": "doctoc README.md",
    "postinstall": "bun db:generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.901.0",
    "@aws-sdk/cloudfront-signer": "3.1036.0",
    "@aws-sdk/s3-presigned-post": "3.901.0",
    "@aws-sdk/s3-request-presigner": "3.901.0",
    "@better-auth/oauth-provider": "1.5.4",
    "@better-auth/prisma-adapter": "1.5.4",
    "@better-auth/stripe": "1.5.4",
    "@daytonaio/sdk": "0.161.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@orpc/openapi": "1.13.8",
    "@orpc/server": "1.13.8",
    "@orpc/zod": "1.13.8",
    "@prisma/client": "6.7.0",
    "@repo/ai": "workspace:*",
    "@repo/analytics": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/constants": "workspace:*",
    "@repo/email": "workspace:*",
    "@repo/logs": "workspace:*",
    "@repo/utils": "workspace:*",
    "better-auth": "1.5.4",
    "hono": "4.8.4",
    "nanoid": "5.1.7",
    "prisma": "6.7.0",
    "stripe": "18.4.0",
    "zod": "3.25.49"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.3.15",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "24.10.1",
    "pglite-prisma-adapter": "0.7.2"
  },
  "prisma": {
    "schema": "db/schema.prisma"
  }
}
