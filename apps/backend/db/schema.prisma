// ---------------------- START SETUP ---------------------- //

// Define our actual prisma client

generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

// Define our database connection

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------- END SETUP ---------------------- //

/// Core user identity (created by Better Auth on signup)
model User {
  id                    String              @id @default(cuid())
  name                  String
  email                 String
  emailVerified         Boolean
  image                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  defaultOrganizationId String?
  role                  String?
  banned                Boolean?
  banReason             String?
  banExpires            DateTime?
  members               Member[]
  invitations           Invitation[]
  sessions              Session[]
  accounts              Account[]
  oauthClients          OauthClient[]
  oauthRefreshTokens    OauthRefreshToken[]
  oauthAccessTokens     OauthAccessToken[]
  oauthConsents         OauthConsent[]
  mcpSessions           McpSession[]
  // Unused but added by better auth migrations
  stripeCustomerId      String?

  @@unique([email])
  @@map("user")
}

/// Team/workspace that groups members (can be personal or shared)
model Organization {
  id               String       @id @default(cuid())
  name             String
  slug             String?
  logo             String?
  createdAt        DateTime     @default(now())
  metadata         String?
  isPersonal       Boolean      @default(false)
  stripeCustomerId String?
  members          Member[]
  invitations      Invitation[]
  mcpSessions      McpSession[]

  @@unique([slug])
  @@map("organization")
}

/// Active login session for user
model Session {
  id                   String              @id @default(cuid())
  expiresAt            DateTime
  token                String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy       String?
  activeOrganizationId String?
  oauthRefreshTokens   OauthRefreshToken[]
  oauthAccessTokens    OauthAccessToken[]

  @@unique([token])
  @@index([userId])
  @@map("session")
}

/// Linked auth provider (email/password, Google, GitHub, etc.) - one user can have multiple accounts
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

/// Short-lived verification tokens for email confirmation, password reset, etc
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

/// Join table linking a user to an organization with a role (owner, admin, member)
model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

/// Pending invite to join an organization
model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  createdAt      DateTime     @default(now())
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

/// Stripe subscription record. Tracks plan, billing interval, trial, and cancellation state
model Subscription {
  id                   String    @id @default(cuid())
  plan                 String
  referenceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String?
  seats                Int?
  periodStart          DateTime?
  periodEnd            DateTime?
  cancelAtPeriodEnd    Boolean?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAt             DateTime?
  canceledAt           DateTime?
  endedAt              DateTime?
  billingInterval      String?
  stripeScheduleId     String?

  @@map("subscription")
}

/// Registered OAuth 2.0 client application (e.g. MCP clients). Defines allowed scopes, redirects, and grant types
model OauthClient {
  id                      String              @id
  clientId                String
  clientSecret            String?
  disabled                Boolean?            @default(false)
  skipConsent             Boolean?
  enableEndSession        Boolean?
  subjectType             String?
  scopes                  String[]
  userId                  String?
  user                    User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime?
  updatedAt               DateTime?
  name                    String?
  uri                     String?
  icon                    String?
  contacts                String[]
  tos                     String?
  policy                  String?
  softwareId              String?
  softwareVersion         String?
  softwareStatement       String?
  redirectUris            String[]
  postLogoutRedirectUris  String[]
  tokenEndpointAuthMethod String?
  grantTypes              String[]
  responseTypes           String[]
  public                  Boolean?
  type                    String?
  requirePKCE             Boolean?
  referenceId             String?
  metadata                Json?
  oauthRefreshTokens      OauthRefreshToken[]
  oauthAccessTokens       OauthAccessToken[]
  oauthConsents           OauthConsent[]

  @@unique([clientId])
  @@map("oauthClient")
}

/// Long-lived refresh token issued to an OAuth client. Used to obtain new access tokens
model OauthRefreshToken {
  id                String             @id
  token             String
  clientId          String
  oauthClient       OauthClient        @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  sessionId         String?
  session           Session?           @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId       String?
  expiresAt         DateTime?
  createdAt         DateTime?
  revoked           DateTime?
  authTime          DateTime?
  scopes            String[]
  oauthAccessTokens OauthAccessToken[]

  @@map("oauthRefreshToken")
}

/// Short-lived access token granting an OAuth client access to protected resources on behalf of a user
model OauthAccessToken {
  id                String             @id
  token             String?
  clientId          String
  oauthClient       OauthClient        @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  sessionId         String?
  session           Session?           @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId            String?
  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId       String?
  refreshId         String?
  oauthRefreshToken OauthRefreshToken? @relation(fields: [refreshId], references: [id], onDelete: Cascade)
  expiresAt         DateTime?
  createdAt         DateTime?
  scopes            String[]

  @@unique([token])
  @@map("oauthAccessToken")
}

/// Records a user's consent to grant specific scopes to an OAuth client (avoids re-prompting)
model OauthConsent {
  id          String      @id
  clientId    String
  oauthClient OauthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId String?
  scopes      String[]
  createdAt   DateTime?
  updatedAt   DateTime?

  @@map("oauthConsent")
}

/// JSON Web Key Set entries. Stores public/private key pairs for signing and verifying JWTs
model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

/// Active MCP (Model Context Protocol) session. Ties an MCP transport session to a user and organization
model McpSession {
  id             String        @id // The transport-level mcp-session-id we generate
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@map("mcp_session")
}
